{
  "version": 6,
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Portable release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AEL_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {"name": "release", "configurePreset": "release"}
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "output": {"outputOnFailure": true}
    }
  ]
}

